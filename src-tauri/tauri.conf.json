{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KB MC Launcher",
  "version": "1.0.1",
  "identifier": "com.jonaykb.kb-mc-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KB MC Launcher",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyQUI4RkZBQ0Q3RTYxNkEKUldScVlYN04rbytyUW03bmxQVHkxTlBoTmFwNG1MeVhCc2FQN2l6dWMzQ0Y1L2N5aUJnWlVlYWgK",
      "endpoints": [
        "https://me.jonaykb.com/launcher/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
