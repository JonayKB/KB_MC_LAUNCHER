{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KB MC Launcher",
  "version": "0.1.0",
  "identifier": "com.jonaykb.kb-mc-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KB MC Launcher",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "theme": "Dark",
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEQkRDRjAyMDczM0RFNjUKUldSbDNqTUhBcys5ZllMaFdDcjdaRklWMmhSV21JS1F6V1d4WlNVSGVFUVp5Tm1LTUR3S2ZaOWYK",
      "endpoints": [
        "https://me.jonaykb.com/update/launcher/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}